{
  "name": "seat-picker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "deploy": "node scripts/deploy-pages-version.mjs latest",
    "deploy:latest": "node scripts/deploy-pages-version.mjs latest",
